+    /// soft — we only need to bound growth, not enforce a strict
+    /// upper bound.
+    #[inline]
+    fn may_admit_stream(&self, stream_id: u64) -> bool {
+        if self.stream_stats.contains_key(&stream_id) {
+            return true;
+        }
+        self.stream_stats.len() < MAX_STREAM_STATS
+    }
